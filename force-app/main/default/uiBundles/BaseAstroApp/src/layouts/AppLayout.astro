---
import '@styles/global.css';
import NavBar from '@components/NavBar.astro';

interface Props { title?: string; eyebrow?: string; heading?: string; subheading?: string }
const { title = 'Astro UI Bundle', eyebrow, heading, subheading } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen text-slate-900 antialiased">
    <NavBar />
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
      {(eyebrow || heading || subheading) && (
        <header class="mb-8">
          {eyebrow && (
            <p class="text-xs font-semibold uppercase tracking-[0.14em] text-indigo-600">{eyebrow}</p>
          )}
          {heading && (
            <h1 class="mt-1 text-3xl sm:text-4xl font-semibold tracking-tight text-slate-900">{heading}</h1>
          )}
          {subheading && (
            <p class="mt-2 text-slate-600 max-w-2xl">{subheading}</p>
          )}
        </header>
      )}
      <slot />
    </main>
    <footer class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 text-xs text-slate-500">
      Built with Astro · Served as a Salesforce UI Bundle
    </footer>
  </body>
</html>
