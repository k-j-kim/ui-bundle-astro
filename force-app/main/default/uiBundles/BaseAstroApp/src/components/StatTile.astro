---
interface Props { label: string; value: string; delta?: string; tone?: 'up' | 'down' | 'flat'; icon?: string }
const { label, value, delta, tone = 'flat', icon } = Astro.props;
const toneClass =
  tone === 'up'   ? 'text-emerald-700 bg-emerald-50 ring-emerald-200' :
  tone === 'down' ? 'text-rose-700 bg-rose-50 ring-rose-200' :
                    'text-slate-600 bg-slate-50 ring-slate-200';
---
<div class="rounded-2xl bg-white ring-1 ring-slate-200 p-5 shadow-sm shadow-slate-900/5">
  <div class="flex items-start justify-between gap-3">
    <div>
      <p class="text-xs font-medium uppercase tracking-wide text-slate-500">{label}</p>
      <p class="mt-2 text-3xl font-semibold tracking-tight text-slate-900">{value}</p>
    </div>
    {icon && (
      <span class="inline-flex size-10 items-center justify-center rounded-xl bg-gradient-to-br from-indigo-50 to-fuchsia-50 text-lg ring-1 ring-indigo-100">
        {icon}
      </span>
    )}
  </div>
  {delta && (
    <p class:list={['mt-3 inline-flex items-center gap-1 px-2 py-0.5 text-xs font-medium rounded-full ring-1', toneClass]}>
      {tone === 'up' ? '▲' : tone === 'down' ? '▼' : '•'} {delta}
    </p>
  )}
</div>
