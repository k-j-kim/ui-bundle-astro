---
interface Props {
  title?: string;
  code: string; // pre-rendered HTML with token spans
}
const { title = 'terminal', code } = Astro.props;
---
<div class="relative">
  <div class="absolute -inset-px rounded-[15px] bg-gradient-to-br from-[#ff5d01]/30 via-transparent to-[#6366f1]/20 blur-md opacity-50 -z-10"></div>
  <div class="rounded-[14px] border border-white/10 overflow-hidden bg-[#0a0c12] shadow-2xl">
    <div class="flex items-center gap-2 px-4 py-3 border-b border-white/[0.06] bg-white/[0.02]">
      <span class="w-3 h-3 rounded-full bg-[#ff5f57]"></span>
      <span class="w-3 h-3 rounded-full bg-[#febc2e]"></span>
      <span class="w-3 h-3 rounded-full bg-[#28c840]"></span>
      <span class="ml-3 text-xs font-mono text-[var(--color-fg-dim)]">{title}</span>
    </div>
    <pre class="code-block !rounded-none !border-0 !shadow-none m-0 text-left" set:html={code}></pre>
  </div>
</div>
