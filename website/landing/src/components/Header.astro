---
import Logo from './Logo.astro';
---
<header class="sticky top-0 z-50 backdrop-blur-md border-b border-white/[0.06] bg-[rgba(7,8,11,0.7)]">
  <div class="container-x flex items-center justify-between h-16">
    <Logo />
    <nav class="hidden md:flex items-center gap-8 text-sm text-[var(--color-fg-muted)]">
      <a href="#features" class="hover:text-white transition-colors">Features</a>
      <a href="#how" class="hover:text-white transition-colors">How it works</a>
      <a href="#quickstart" class="hover:text-white transition-colors">Quick start</a>
      <a href="https://k-j-kim.github.io/ui-bundle-astro-docs/" class="hover:text-white transition-colors">Docs</a>
    </nav>
    <div class="flex items-center gap-2">
      <a href="https://github.com/k-j-kim/ui-bundle-astro" class="btn btn-ghost text-sm" aria-label="GitHub repository">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 .5a12 12 0 0 0-3.79 23.4c.6.11.82-.26.82-.58v-2c-3.34.73-4.04-1.61-4.04-1.61-.55-1.4-1.34-1.78-1.34-1.78-1.09-.74.08-.73.08-.73 1.21.09 1.84 1.24 1.84 1.24 1.07 1.84 2.81 1.31 3.5 1 .1-.78.42-1.31.76-1.61-2.66-.31-5.46-1.33-5.46-5.93 0-1.31.47-2.38 1.24-3.22-.13-.31-.54-1.54.11-3.22 0 0 1.01-.32 3.31 1.23a11.5 11.5 0 0 1 6.03 0c2.3-1.55 3.31-1.23 3.31-1.23.66 1.68.24 2.91.12 3.22.77.84 1.24 1.91 1.24 3.22 0 4.61-2.81 5.62-5.49 5.92.43.37.81 1.1.81 2.22v3.29c0 .32.22.7.83.58A12 12 0 0 0 12 .5Z"/>
        </svg>
        <span class="hidden sm:inline">GitHub</span>
      </a>
      <a href="#quickstart" class="btn btn-primary text-sm hidden sm:inline-flex">Get started</a>
    </div>
  </div>
</header>
