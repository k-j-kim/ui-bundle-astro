---
interface Props {
  title: string;
  icon: string;
}
const { title, icon } = Astro.props;
---
<div class="card group">
  <div class="flex items-center gap-3 mb-3">
    <div class="w-10 h-10 rounded-lg flex items-center justify-center bg-gradient-to-br from-white/[0.04] to-white/[0.01] border border-white/[0.08] text-[var(--color-brand)]" set:html={icon}></div>
    <h3 class="text-base font-semibold text-white">{title}</h3>
  </div>
  <div class="text-sm text-[var(--color-fg-muted)] leading-relaxed">
    <slot />
  </div>
</div>
