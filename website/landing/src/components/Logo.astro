---
interface Props {
  size?: number;
}
const { size = 28 } = Astro.props;
---
<a href="/" class="inline-flex items-center gap-2 group" aria-label="Puebla home">
  <svg width={size} height={size} viewBox="0 0 64 64" aria-hidden="true">
    <defs>
      <linearGradient id="logo-g" x1="0" y1="0" x2="1" y2="1">
        <stop offset="0%" stop-color="#ff7a2e"/>
        <stop offset="100%" stop-color="#ff5d01"/>
      </linearGradient>
    </defs>
    <rect width="64" height="64" rx="14" fill="#0d0f14" stroke="rgba(255,255,255,0.08)"/>
    <path d="M20 18h12c7 0 12 4 12 11s-5 11-12 11h-5v8h-7V18Zm7 16h5c3 0 5-1.8 5-5s-2-5-5-5h-5v10Z" fill="url(#logo-g)"/>
  </svg>
  <span class="font-semibold tracking-tight text-[1.05rem] text-white group-hover:text-white">Puebla</span>
</a>
